---
import Layout from './Layout.astro';

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title}>
    <article class="post">
        <header>
            <h1>{frontmatter.title}</h1>
            <time datetime={frontmatter.pubDate.toISOString()}>
                {frontmatter.pubDate.toLocaleDateString('zh-CN')}
            </time>
        </header>
        <div class="content">
            <slot />
        </div>
    </article>
    <a href="/blog/" class="back">← 返回文章列表</a>
</Layout>

<style>
    .post {
        max-width: 720px;
        margin: 2rem auto;
        padding: 0 1rem;
    }
    header {
        margin-bottom: 2rem;
    }
    header h1 {
        margin: 0 0 0.5rem;
    }
    time {
        color: #888;
        font-size: 0.9rem;
    }
    .content {
        line-height: 1.8;
    }
    .content :global(table) {
        border-collapse: collapse;
        margin: 1rem 0;
    }
    .content :global(th),
    .content :global(td) {
        border: 1px solid #ddd;
        padding: 0.5rem 1rem;
    }
    .content :global(img) {
        max-width: 100%;
        height: auto;
    }
    .back {
        display: block;
        max-width: 720px;
        margin: 2rem auto;
        padding: 0 1rem;
        color: #666;
    }
</style>
